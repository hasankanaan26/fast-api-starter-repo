# --- Ollama Settings (Checkpoint 3) ---
#it is a standard practice to use .env.example to communicate what are the environment variables needed.
#The actual .env file should not be committed to version control, as it may contain sensitive information or machine-specific settings.
#Don't put your real secrets and credentials here!!!!!     
OLLAMA_BASE_URL=http://localhost:11434 #change this to the model you downloaded
OLLAMA_MODEL=llama3.2
