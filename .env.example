# --- Ollama Settings (Checkpoint 3) ---
#it is a standard practice to use .env.example to communicate what are the environment variables needed.
#The actual .env file should not be committed to version control, as it may contain sensitive information or machine-specific settings.
#Don't put your real secrets and credentials here!!!!!     
OLLAMA_BASE_URL=http://localhost:11434 #change this to the model you downloaded
OLLAMA_MODEL=llama3.2


# --- Gemini Settings (used when LLM_PROVIDER=gemini) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Azure OpenAI Settings (used when LLM_PROVIDER=azure) ---
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini

# --- UV Build Settings ---
UV_LINK_MODE=copy
UV_COMPILE_BYTECODE=1

# --- Resilience Settings (Checkpoint 3+) ---
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=30
LLM_RETRY_DELAY=1.0
